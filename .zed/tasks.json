[
  {
    "label": "Build library",
    "command": "python",
    "args": [
      "build.py",
      "build"
    ]
  },
  {
    "label": "Run unit tests",
    "command": "python",
    "args": [
      "build.py",
      "test"
    ]
  },
  {
    "label": "Build example",
    "command": "python",
    "args": [
      "build.py",
      "example"
    ]
  },
  {
    "label": "Run integration test (interactive)",
    "command": "python",
    "args": [
      "build.py",
      "test-integration"
    ],
    "env": {
      "AXIDEV_IO_RUN_INTEGRATION_TESTS": "1",
      "AXIDEV_IO_INTERACTIVE": "1"
    }
  },
  {
    "label": "Package",
    "command": "python",
    "args": [
      "build.py",
      "package"
    ]
  },
  {
    "label": "Clean",
    "command": "python",
    "args": [
      "build.py",
      "clean"
    ]
  }
]
